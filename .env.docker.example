# =============================================================================
# Docker Compose — root .env
# Copy to .env in the repo root. See Backend/.env.example for full key docs.
# =============================================================================

COMPOSE_PROJECT_NAME=shopai

# -----------------------------------------------------------------------------
# PORTS
# -----------------------------------------------------------------------------
BACKEND_PORT=2030
FRONTEND_PORT=3000
MONGO_PORT=27017

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
MONGO_INITDB_DATABASE=ShopAI
# Inside Compose network (service name = mongodb). For Atlas, set Atlas URI here instead.
MONGO_URL=mongodb://mongodb:27017/ShopAI

# -----------------------------------------------------------------------------
# URLS
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:2030/shopai

# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------
JWT_KEY=change-me-in-production-min-32-chars
JWT_REFRESH_KEY=change-me-refresh-in-production-min-32-chars

# -----------------------------------------------------------------------------
# PAYMENTS — Stripe
# -----------------------------------------------------------------------------
STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# MEDIA — Cloudinary
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET_KEY=

# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------
EMAIL_PROVIDER=resend
EMAIL_FROM=ShopAI <noreply@example.com>
RESEND_API_KEY=
BREVO_API_KEY=

# -----------------------------------------------------------------------------
# API KEYS — LLM / Chat
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# API KEYS — Semantic search (optional until search service is wired)
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=huggingface
VOYAGE_API_KEY=
JINA_API_KEY=
COHERE_API_KEY=
RERANK_PROVIDER=voyage
RERANK_ENABLED=true

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
NODE_ENV=production
HOST=0.0.0.0
TRUST_PROXY=true
