# Copy to `.env` in the repo root for Docker Compose.
# All values can be overridden per environment (local, staging, production).

COMPOSE_PROJECT_NAME=shopai

# Host ports (change if 2030/3000/27017 are taken)
BACKEND_PORT=2030
FRONTEND_PORT=3000
MONGO_PORT=27017

# Mongo
MONGO_INITDB_DATABASE=ShopAI
# Used inside the backend container (service name = mongodb)
MONGO_URL=mongodb://mongodb:27017/ShopAI

# URLs — set to your public domains in production
FRONTEND_URL=http://localhost:3000
# Baked into the frontend image at build time
REACT_APP_API_URL=http://localhost:2030/shopai

# Backend secrets (use real values in staging/production)
JWT_KEY=change-me-in-production-min-32-chars
JWT_REFRESH_KEY=change-me-refresh-in-production-min-32
STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional: LLM, email, Cloudinary — same keys as Backend/.env.example
OPENROUTER_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET_KEY=

EMAIL_PROVIDER=resend
EMAIL_FROM=ShopAI <noreply@example.com>
RESEND_API_KEY=
BREVO_API_KEY=

# Server / proxy (production behind load balancer)
NODE_ENV=production
HOST=0.0.0.0
TRUST_PROXY=true

# Rate limits (optional overrides)
# RATE_LIMIT_API_MAX=200
# RATE_LIMIT_AUTH_MAX=15
# RATE_LIMIT_CHAT_MAX=15
