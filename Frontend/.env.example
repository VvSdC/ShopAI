# ─── API URL ──────────────────────────────────────────────────
# Must match Backend PORT and include /shopai prefix (see app.js routes).
# Local dev default: http://localhost:2030/shopai
# Docker Compose: set REACT_APP_API_URL in root .env (baked at image build)
# Production: https://api.yourdomain.com/shopai
REACT_APP_API_URL=http://localhost:2030/shopai
