# =============================================================================
# ShopAI Frontend — environment variables
# Copy to Frontend/.env.local (CRA loads .env.local in development).
# =============================================================================


# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
# Must include the /shopai prefix (matches Backend route mount).
# Local:     http://localhost:2030/shopai
# Docker:    set REACT_APP_API_URL in root .env (baked at image build)
# Production: https://api.yourdomain.com/shopai
REACT_APP_API_URL=http://localhost:2030/shopai

# Canonical storefront URL for SEO (sitemap, Open Graph, JSON-LD).
# Production: https://shop.yourdomain.com
REACT_APP_SITE_URL=http://localhost:3000
