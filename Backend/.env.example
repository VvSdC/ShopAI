# ─── Authentication ───────────────────────────────────────────
JWT_KEY=your_jwt_secret_here
JWT_REFRESH_KEY=your_jwt_refresh_secret_here

# ─── Database ─────────────────────────────────────────────────
MONGO_URL=mongodb://127.0.0.1:27017/ShopAI

# ─── Stripe (Payments) ───────────────────────────────────────
STRIPE_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudinary (Image Uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET_KEY=your_api_secret

# ─── Frontend URL (CORS) ─────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── AI Chatbot ──────────────────────────────────────────────
# 3-layer fallback: Cerebras → HuggingFace → OpenRouter
# Fill in at least one provider. The system tries them in order
# and falls back on rate limits (429).

# Cerebras — https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL=qwen-3-8b

# HuggingFace Inference API — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b
