# Copy to Backend/.env — never commit .env

# Server
NODE_ENV=development
PORT=2030
HOST=0.0.0.0
TRUST_PROXY=false

# Database
MONGO_URL=mongodb://127.0.0.1:27017/ShopAI

# Redis (optional — BullMQ queues + shared response cache)
# Leave REDIS_URL unset for local dev without Redis; API falls back to Mongo and checkout uses poll + webhook.
REDIS_URL=redis://127.0.0.1:6379
ENABLE_CHECKOUT_QUEUE=false
ENABLE_EMBEDDING_SYNC_QUEUE=false
ENABLE_MODERATION_QUEUE=false
ENABLE_PRODUCT_TAGGING_QUEUE=false
# BullMQ workers: default true in development/test, false in production (see config.isProduction).
# Production: leave unset or false on the API service; run workers separately: npm run start:worker
# Local dev: true (workers in same process as nodemon) or false + start:worker in a second terminal
RUN_QUEUE_WORKERS_IN_API=true

# Auth
JWT_KEY=your_jwt_secret_here
JWT_REFRESH_KEY=your_jwt_refresh_secret_here
# Max concurrent refresh-token sessions per user (multi-device)
AUTH_MAX_SESSIONS=5

# Frontend
FRONTEND_URL=http://localhost:3000
# Optional — public API URL for CSP connectSrc (defaults to 'self' + FRONTEND_URL)
API_PUBLIC_URL=http://localhost:2030

# Stripe
STRIPE_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET_KEY=your_api_secret

# Email
EMAIL_PROVIDER=resend
EMAIL_FROM=ShopAI <noreply@your-verified-domain.com>
RESEND_API_KEY=re_...
BREVO_API_KEY=xkeysib-...

# API configurations (chat fallback: OpenRouter → Gemini → Mistral → HF → Groq)

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Hugging Face
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Search — embeddings
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
VOYAGE_API_KEY=
JINA_API_KEY=
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Search — rerank
RERANK_PROVIDER=voyage
RERANK_ENABLED=true
RERANK_TOP_N=30
RERANK_MODEL=rerank-2.5
COHERE_API_KEY=
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5
HF_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Search — sync
SEARCH_AUTO_SYNC_EMBEDDINGS=true
SEARCH_SYNC_DELAY_MS=1200
SEARCH_SYNC_CONCURRENCY=5
SEARCH_SYNC_STARTUP_DELAY_MS=5000
SEARCH_EMBEDDING_VERSION=1
SEARCH_QUERY_EMBED_CACHE_TTL=3600

# Chat — LangGraph is the only LLM pipeline; deterministic assist adds rule-based fallbacks after it
ENABLE_CHAT_DETERMINISTIC_ASSIST=true

# Rate limits (optional)
# RATE_LIMIT_API_MAX=200
# RATE_LIMIT_CHAT_MAX=15

# OpenAPI / Swagger UI (default: on in dev/test, off in production)
# OPENAPI_ENABLED=true
