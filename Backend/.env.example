# ─── Server ───────────────────────────────────────────────────
PORT=2030
HOST=0.0.0.0
# Set true when behind nginx / load balancer (production, Docker)
TRUST_PROXY=false

# ─── Authentication ───────────────────────────────────────────
JWT_KEY=your_jwt_secret_here
JWT_REFRESH_KEY=your_jwt_refresh_secret_here

# ─── Database ─────────────────────────────────────────────────
MONGO_URL=mongodb://127.0.0.1:27017/ShopAI

# ─── Stripe (Payments) ───────────────────────────────────────
STRIPE_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Cloudinary (Image Uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET_KEY=your_api_secret

# ─── Frontend URL (CORS + Stripe redirects) ──────────────────
FRONTEND_URL=http://localhost:3000

# ─── Environment ─────────────────────────────────────────────
NODE_ENV=development

# ─── Email Service ───────────────────────────────────────────
# Fill in at least one provider. Use EMAIL_PROVIDER to pick which runs first.

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Brevo — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-...

# Which provider to try first: brevo | resend (default: resend then brevo)
EMAIL_PROVIDER=brevo

# From address — MUST be verified in your active provider (Brevo: Senders & Domains)
# Do NOT use onboarding@resend.dev when sending via Brevo
EMAIL_FROM=ShopAI <you@your-verified-domain.com>

# ─── AI Chatbot ──────────────────────────────────────────────
# Fallback chain: OpenRouter → Gemini → Mistral → HuggingFace
# Fill in at least one provider. Skips missing keys; falls back on 429/errors.

# OpenRouter (primary) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b

# Google Gemini (free tier) — https://aistudio.google.com/apikey
# gemini-2.0-flash and gemini-2.5-flash support tool calling via OpenAI compat
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Mistral (Experiment/free tier) — https://console.mistral.ai/api-keys
# mistral-small-latest supports function calling; rate limits apply on free plan
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# HuggingFace Inference Router — https://huggingface.co/settings/tokens
# Uses router.huggingface.co (not legacy api-inference.huggingface.co)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# ─── Rate limits (optional overrides) ────────────────────────
# RATE_LIMIT_API_WINDOW_MS=900000
# RATE_LIMIT_API_MAX=200
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=15
# RATE_LIMIT_CHAT_WINDOW_MS=60000
# RATE_LIMIT_CHAT_MAX=15
