# =============================================================================
# ShopAI Backend — environment variables
# Copy to Backend/.env and fill in values. Never commit .env to git.
# =============================================================================


# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=2030
HOST=0.0.0.0
# Set true when behind nginx, Render, or another reverse proxy
TRUST_PROXY=false


# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# Local: mongodb://127.0.0.1:27017/ShopAI
# Atlas (free M0, no card): https://cloud.mongodb.com → Connect → Drivers
MONGO_URL=mongodb://127.0.0.1:27017/ShopAI


# -----------------------------------------------------------------------------
# AUTH / JWT
# -----------------------------------------------------------------------------
# Use long random strings (32+ chars). openssl rand -hex 32
JWT_KEY=your_jwt_secret_here
JWT_REFRESH_KEY=your_jwt_refresh_secret_here


# -----------------------------------------------------------------------------
# FRONTEND / CORS
# -----------------------------------------------------------------------------
# Used for CORS, Stripe redirects, and OpenRouter HTTP-Referer
FRONTEND_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# PAYMENTS — Stripe
# -----------------------------------------------------------------------------
# https://dashboard.stripe.com/test/apikeys
STRIPE_KEY=sk_test_...
# https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...


# -----------------------------------------------------------------------------
# MEDIA — Cloudinary
# -----------------------------------------------------------------------------
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET_KEY=your_api_secret


# -----------------------------------------------------------------------------
# EMAIL
# -----------------------------------------------------------------------------
# Provider tried first: resend | brevo (falls back to the other if configured)
EMAIL_PROVIDER=resend
EMAIL_FROM=ShopAI <noreply@your-verified-domain.com>

# Resend — https://resend.com/api-keys (free tier, no card)
RESEND_API_KEY=re_...

# Brevo — https://app.brevo.com/settings/keys/api (free tier, no card)
BREVO_API_KEY=xkeysib-...


# -----------------------------------------------------------------------------
# API KEYS — LLM / Chat (fallback chain: OpenRouter → Gemini → Mistral → HF)
# Configure at least one. Missing keys are skipped automatically.
# -----------------------------------------------------------------------------

# OpenRouter — https://openrouter.ai/keys (no card; use :free models for chat)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-8b

# Google Gemini — https://aistudio.google.com/apikey (no card)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Alias accepted by env.js if GEMINI_API_KEY is empty
GOOGLE_API_KEY=

# Mistral — https://console.mistral.ai/api-keys (Experiment plan, no card)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# Hugging Face — https://huggingface.co/settings/tokens (no card)
# Chat uses router.huggingface.co; embeddings use hf-inference (see SEARCH section)
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct

# Groq — https://console.groq.com/keys (optional extra LLM fallback, no card)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant


# -----------------------------------------------------------------------------
# API KEYS — Semantic search (embeddings + rerank)
# Planned for Atlas Vector Search + hybrid retrieval. Configure when implemented.
# -----------------------------------------------------------------------------

# --- Embeddings (index products + embed queries) ---
# Primary provider: huggingface | gemini | voyage | jina | openrouter
EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Voyage AI — https://dash.voyageai.com/ (200M free tokens, no card)
# Also provides rerank-2 / rerank-2.5 in the same pool
VOYAGE_API_KEY=

# Jina AI — https://jina.ai/?sui=apikey (10M free tokens, no card)
# Embeddings + reranker share one token pool
JINA_API_KEY=

# OpenRouter embeddings fallback — e.g. openai/text-embedding-3-small
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# Gemini embeddings fallback — text-embedding-004
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- Reranker (re-order top search results; optional but improves quality) ---
# Primary provider: voyage | jina | cohere | openrouter | huggingface | off
RERANK_PROVIDER=voyage
RERANK_ENABLED=true
RERANK_TOP_N=30
RERANK_MODEL=rerank-2.5

# Cohere — https://dashboard.cohere.com/ (trial ~1k calls/mo, no card; dev only)
COHERE_API_KEY=

# OpenRouter rerank — https://openrouter.ai/docs/api/api-reference/rerank/create-rerank
# Uses paid routes (~$0.001/search); not covered by :free chat models
OPENROUTER_RERANK_MODEL=cohere/rerank-v3.5

# Hugging Face cross-encoder reranker (serverless, same HF token as above)
HF_RERANK_MODEL=BAAI/bge-reranker-v2-m3

# --- Search tuning (optional) ---
# SEARCH_VECTOR_CANDIDATES=100
# SEARCH_VECTOR_LIMIT=50
# SEARCH_KEYWORD_LIMIT=50
# SEARCH_RRF_K=60


# -----------------------------------------------------------------------------
# RATE LIMITS (optional overrides)
# -----------------------------------------------------------------------------
# RATE_LIMIT_API_WINDOW_MS=900000
# RATE_LIMIT_API_MAX=200
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=15
# RATE_LIMIT_CHAT_WINDOW_MS=60000
# RATE_LIMIT_CHAT_MAX=15
