{
  "name": "shopai",
  "version": "1.0.0",
  "description": "shopai server",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "server": "nodemon server.js",
    "start": "concurrently --names server,stripe --prefix-colors cyan,magenta \"nodemon server.js\" \"stripe listen --forward-to localhost:2030/webhook\"",
    "start:server": "node server.js",
    "dev": "concurrently --names server,stripe --prefix-colors cyan,magenta \"nodemon server.js\" \"stripe listen --forward-to localhost:2030/webhook\"",
    "lint": "eslint . --ext .js --config .eslintrc.cjs",
    "lint:fix": "eslint . --ext .js --fix --config .eslintrc.cjs",
    "depcheck": "depcheck"
  },
  "keywords": [
    "API",
    "NodeJS"
  ],
  "author": "VVSD Charan",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.31.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^6.8.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "resend": "^6.12.3",
    "stripe": "^11.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "eslint": "^8.45.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^4.0.0",
    "nodemon": "^2.0.22"
  }
}
