{
  "name": "shopai",
  "version": "1.0.0",
  "description": "shopai server",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "server": "nodemon server.js",
    "start": "concurrently --names server,stripe --prefix-colors cyan,magenta \"nodemon server.js\" \"stripe listen --forward-to localhost:2030/webhook\"",
    "start:server": "node server.js",
    "start:worker": "node worker.js",
    "dev": "concurrently --names server,stripe --prefix-colors cyan,magenta \"nodemon server.js\" \"stripe listen --forward-to localhost:2030/webhook\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:keys": "node scripts/test-keys.js",
    "search:reindex": "node scripts/reindex-embeddings.js",
    "lint": "eslint . --ext .js --config .eslintrc.cjs",
    "lint:fix": "eslint . --ext .js --fix --config .eslintrc.cjs",
    "depcheck": "depcheck"
  },
  "keywords": [
    "API",
    "NodeJS"
  ],
  "author": "VVSD Charan",
  "license": "ISC",
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.0",
    "cloudinary": "^1.31.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^6.8.2",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "rate-limit-redis": "^5.0.0",
    "resend": "^6.12.3",
    "stripe": "^11.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "concurrently": "^9.2.1",
    "depcheck": "^1.4.7",
    "eslint": "^8.45.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-security": "^4.0.0",
    "mongodb-memory-server": "^10.2.0",
    "nodemon": "^2.0.22",
    "supertest": "^7.1.4",
    "vitest": "^3.2.4"
  }
}
